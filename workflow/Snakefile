# QC tools and reports
use rule mosdepth from qc as qc_mosdepth with:
    input:
        bam="alignment/pbmm2_align/{sample}_N.bam",
        bai="alignment/pbmm2_align/{sample}_N.bam.bai",


use rule multiqc_longread from qc as qc_multiqc_longread


use rule sequali from qc as qc_sequali with:
    input:
        infile="alignment/pbmm2_align/{sample}_{type}_{processing_unit}_{barcode}.bam",


use rule picard_collect_alignment_summary_metrics from qc as qc_picard_collect_alignment_summary_metrics with:
    input:
        bam="alignment/pbmm2_align/{sample}_N.bam",
        bai="alignment/pbmm2_align/{sample}_N.bam.bai",
        ref=config.get("reference", {}).get("fasta", ""),


_dict_path = (
    "references/samtools_dict/%s.dict" % os.path.splitext(os.path.basename(config.get("reference", {}).get("fasta", "")))[0]
)


rule samtools_dict:
    input:
        fasta=config.get("reference", {}).get("fasta", ""),
    output:
        _dict_path,
    log:
        f"{_dict_path}.log",
    benchmark:
        repeat(
            f"{_dict_path}.benchmark.tsv",
            config.get("samtools_dict", {}).get("benchmark_repeats", 1),
        )
    threads: config.get("samtools_dict", {}).get("threads", config["default_resources"]["threads"])
    resources:
        mem_mb=config.get("samtools_dict", {}).get("mem_mb", config["default_resources"]["mem_mb"]),
        mem_per_cpu=config.get("samtools_dict", {}).get("mem_per_cpu", config["default_resources"]["mem_per_cpu"]),
        partition=config.get("samtools_dict", {}).get("partition", config["default_resources"]["partition"]),
        threads=config.get("samtools_dict", {}).get("threads", config["default_resources"]["threads"]),
        time=config.get("samtools_dict", {}).get("time", config["default_resources"]["time"]),
    container:
        config.get("samtools_dict", {}).get("container", config.get("default_container", ""))
    shell:
        "samtools dict {input.fasta} > {output} 2> {log}"


rule references_bed_to_interval_list:
    input:
        bed=config.get("reference", {}).get("design_bed", ""),
        ref_dict=_dict_path,
    output:
        temp(
            "references/bed_to_interval_list/%s.interval_list"
            % os.path.basename(config.get("reference", {}).get("design_bed", ""))
        ),
    log:
        "references/bed_to_interval_list/%s.interval_list.log"
        % os.path.basename(config.get("reference", {}).get("design_bed", "")),
    benchmark:
        repeat(
            "references/bed_to_interval_list/%s.interval_list.benchmark.tsv"
            % os.path.basename(config.get("reference", {}).get("design_bed", "")),
            config.get("bed_to_interval_list", {}).get("benchmark_repeats", 1),
        )
    threads: config.get("bed_to_interval_list", {}).get("threads", config["default_resources"]["threads"])
    resources:
        mem_mb=config.get("bed_to_interval_list", {}).get("mem_mb", config["default_resources"]["mem_mb"]),
        mem_per_cpu=config.get("bed_to_interval_list", {}).get("mem_per_cpu", config["default_resources"]["mem_per_cpu"]),
        partition=config.get("bed_to_interval_list", {}).get("partition", config["default_resources"]["partition"]),
        threads=config.get("bed_to_interval_list", {}).get("threads", config["default_resources"]["threads"]),
        time=config.get("bed_to_interval_list", {}).get("time", config["default_resources"]["time"]),
    container:
        config.get("bed_to_interval_list", {}).get("container", config.get("default_container", ""))
    shell:
        "gatk BedToIntervalList -I {input.bed} -O {output} -SD {input.ref_dict} &> {log}"


use rule picard_collect_hs_metrics from qc as qc_picard_collect_hs_metrics with:
    input:
        bam="alignment/pbmm2_align/{sample}_N.bam",
        bai="alignment/pbmm2_align/{sample}_N.bam.bai",
        bait_intervals="references/bed_to_interval_list/%s.interval_list"
        % config.get("reference", {}).get("design_bed", "").split("/")[-1],
        reference=config.get("reference", {}).get("fasta", ""),
        target_intervals="references/bed_to_interval_list/%s.interval_list"
        % config.get("reference", {}).get("design_bed", "").split("/")[-1],


# CNVKit PON
# targets (bed)
use rule cnvkit_create_targets from references as references_cnvkit_create_targets


# anti-targets (bed)
use rule cnvkit_create_anti_targets from references as references_cnvkit_create_anti_targets


# collect sample names from units
# to use in PoN files creation
sample_names = get_units_column(units, "sample")


# make PoN (.cnn)
# input is overriden because natively this rule uses get_bam()
# to extract BAM paths from units.tsv (unmapped)
# but we need mapped BAM files
use rule cnvkit_build_normal_reference from references as references_cnvkit_build_normal_reference with:
    input:
        bams=expand("alignment/pbmm2_align/{sample}_N.bam", sample=sample_names),
        target="references/cnvkit_create_targets/cnvkit_manifest.target.bed",
        antitarget="references/cnvkit_create_anti_targets/cnvkit_manifest.antitarget.bed",
        ref=config.get("reference", {}).get("fasta", ""),
        mappability=config.get("reference", {}).get("mappability", ""),


# SNV PON
# majority of bam files will be unmapped
# so, map them
use rule pbmarkdup from prealignment as prealignment_pbmarkdup


use rule pbmm2_index from alignment as alignment_pbmm2_index


use rule pbmm2_align from alignment as alignment_pbmm2_align with:
    input:
        query="prealignment/pbmarkdup/{sample}_{type}_{processing_unit}_{barcode}.bam",
        reference=expand(
            "alignment/pbmm2_index/{ref}.{preset}.mmi",
            ref=os.path.basename(config.get("reference", {}).get("fasta", "")),
            preset=config.get("pbmm2_align", {}).get("preset", ""),
        ),


use rule pbmm2_merge from alignment as alignment_pbmm2_merge with:
    wildcard_constraints:
        type="N",


use rule samtools_index from alignment as alignment_samtools_index_pbmm2 with:
    wildcard_constraints:
        file="^alignment/pbmm2_align/.+",


# run DeepSomatic on normal samples to create PoN
# some options are different compared to the regular deepsomatic
use rule deepsomatic_pon from references as references_deepsomatic_pon


use rule whatshap_phase from snv_indels as snv_indels_whatshap_phase with:
    input:
        vcf="references/deepsomatic_pon/{sample}.pon.vcf.gz",
        bam="alignment/pbmm2_align/{sample}_N.bam",
        bai="alignment/pbmm2_align/{sample}_N.bam.bai",
        fasta=config.get("reference", {}).get("fasta", ""),
    output:
        vcf=temp("snv_indels/whatshap_phase/{sample}.phased.vcf.gz"),
    log:
        "snv_indels/whatshap_phase/{sample}.phased.vcf.gz.log",
    benchmark:
        repeat(
            "snv_indels/whatshap_phase/{sample}.phased.vcf.gz.benchmark.tsv",
            config.get("whatshap_phase", {}).get("benchmark_repeats", 1),
        )


use rule tabix from cnv_sv as cnv_sv_tabix with:
    wildcard_constraints:
        file="^snv_indels/whatshap_phase/.+",


# SV discovery
rule bgzip_sv_vcf:
    input:
        "cnv_sv/{caller}/{sample}_{type}.vcf",
    output:
        temp("cnv_sv/{caller}/{sample}_{type}.vcf.gz"),
    log:
        "cnv_sv/{caller}/{sample}_{type}.vcf.gz.log",
    benchmark:
        repeat(
            "cnv_sv/{caller}/{sample}_{type}.vcf.gz.benchmark.tsv",
            config.get("bgzip_sv_vcf", {}).get("benchmark_repeats", 1),
        )
    threads: config.get("bgzip_sv_vcf", {}).get("threads", config["default_resources"]["threads"])
    resources:
        mem_mb=config.get("bgzip_sv_vcf", {}).get("mem_mb", config["default_resources"]["mem_mb"]),
        mem_per_cpu=config.get("bgzip_sv_vcf", {}).get("mem_per_cpu", config["default_resources"]["mem_per_cpu"]),
        partition=config.get("bgzip_sv_vcf", {}).get("partition", config["default_resources"]["partition"]),
        threads=config.get("bgzip_sv_vcf", {}).get("threads", config["default_resources"]["threads"]),
        time=config.get("bgzip_sv_vcf", {}).get("time", config["default_resources"]["time"]),
    container:
        config.get("bgzip_sv_vcf", {}).get("container", config.get("default_container", ""))
    shell:
        "bgzip -c {input} > {output} 2> {log}"


use rule tabix from cnv_sv as cnv_sv_tabix_sv with:
    wildcard_constraints:
        file="^cnv_sv/(pbsv_call|sniffles2_call)/.+",


# pbsv requires pbmm2 aligner
use rule pbsv_discover from cnv_sv as cnv_sv_pbsv_discover


use rule pbsv_call from cnv_sv as cnv_sv_pbsv_call


use rule sniffles2_call from cnv_sv as cnv_sv_sniffles2_call with:
    input:
        bam="alignment/vacmap_align/{sample}_N.bam",
        bai="alignment/vacmap_align/{sample}_N.bam.bai",
        ref=config.get("reference", {}).get("fasta", ""),


use rule bcftools_merge from references as references_sv_bcftools_merge with:
    input:
        vcfs=expand(
            "cnv_sv/{caller}/{sample}_N.vcf.gz",
            caller=["pbsv_call", "sniffles2_call"],
            sample=sample_names,
        ),
        vcfs_tabix=expand(
            "cnv_sv/{caller}/{sample}_N.vcf.gz.tbi",
            caller=["pbsv_call", "sniffles2_call"],
            sample=sample_names,
        ),
    output:
        normal_vcf=temp("references/bcftools_merge/sv_normal.vcf.gz"),


use rule vacmap_align from alignment as alignment_vacmap_align


use rule vacmap_merge from alignment as alignment_vacmap_merge


use rule samtools_index from alignment as alignment_samtools_index_vacmap with:
    wildcard_constraints:
        file="^alignment/vacmap_align/.+",


use rule bcftools_merge from references as references_snv_bcftools_merge with:
    input:
        vcfs=expand(
            "snv_indels/whatshap_phase/{sample}.phased.vcf.gz",
            sample=sample_names,
        ),
        vcfs_tabix=expand(
            "snv_indels/whatshap_phase/{sample}.phased.vcf.gz.tbi",
            sample=sample_names,
        ),
